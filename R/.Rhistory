get_undata <- function(series_code) {
url <- paste0(
"https://data.un.org/ws/rest/data/UNSD,DF_UNData_UNSD,1.0/..",
series_code,
".?startPeriod=", start_year,
"&endPeriod=", end_year,
"&format=csvdata"
)
response <- GET(url)
if (status_code(response) != 200) {
stop("API request failed. Check the series code or internet connection.")
}
text <- content(response, as = "text", encoding = "UTF-8")
read_csv(I(text), show_col_types = FALSE)
}
