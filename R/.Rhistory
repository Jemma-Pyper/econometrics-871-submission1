# Load all required packages
p_load(
httr,        # sending HTTP requests to the UNdata API
tidyverse,   # data manipulation (dplyr, tidyr) and plotting (ggplot2)
scales,      # formatting axis labels (e.g. percent_format)
ggrepel      # non-overlapping text labels on scatter plots
)
fetch_undata <- function(series_id,
countries = NULL,
start     = 2000,
end       = 2022) {
# UNdata SDMX REST endpoint — no API key required
# URL structure: /data/{agency},{dataflow},{version}/{filter}?params
# Leaving dimension slots empty acts as a wildcard (= "all values")
url <- paste0(
"https://data.un.org/ws/rest/data/",
"UNSD,DF_UNData_UNSD,1.0/",
".", ".", series_id, ".",          # wildcards around the series code
"?startPeriod=", start,
"&endPeriod=",   end,
"&format=csvdata"                  # request CSV — simpler to parse than JSON
)
# Attempt the API call — tryCatch prevents the whole script from crashing
response <- tryCatch(
httr::GET(url, httr::timeout(30)), # 30-second timeout
error = function(e) {
message("  API call failed: ", conditionMessage(e))
NULL
}
)
# If the call succeeded (HTTP 200), parse and return the CSV
if (!is.null(response) && httr::status_code(response) == 200) {
raw_text <- httr::content(response, as = "text", encoding = "UTF-8")
df <- readr::read_csv(I(raw_text), show_col_types = FALSE)
message("  Success — ", nrow(df), " rows returned from API.")
# Filter to our selected countries if a list was provided
if (!is.null(countries) && "REF_AREA" %in% names(df)) {
df <- dplyr::filter(df, REF_AREA %in% countries)
}
return(df)
} else {
# API unavailable — fall back to the built-in sample dataset
message("  API unavailable (status: ",
ifelse(is.null(response), "no response",
httr::status_code(response)),
"). Using built-in sample data instead.")
return(make_sample_data(series_id, countries, start, end))
}
}
make_sample_data <- function(series_id, countries, start, end) {
# Approximate 2000-2022 averages — sourced from World Bank WDI (public domain)
lookup <- tribble(
~country,         ~mean_unemp, ~mean_inflation,
"United States",        6.1,             2.4,
"Germany",              7.8,             1.7,
"Brazil",               9.8,             6.5,
"South Africa",        25.5,             5.8,
"Japan",                3.9,             0.4,
"United Kingdom",       5.5,             2.3,
"India",                5.4,             6.8,
"Nigeria",              6.2,            12.1,
"Australia",            5.4,             2.6,
"Argentina",           10.2,            28.5
)
if (!is.null(countries)) {
lookup <- filter(lookup, country %in% countries)
}
set.seed(42)    # ensures the simulated noise is reproducible
years <- seq(start, end)
value_col <- if (series_id == "SL_TLF_UEM") "mean_unemp" else "mean_inflation"
df <- lookup %>%
select(REF_AREA = country, base = all_of(value_col)) %>%
crossing(TIME_PERIOD = years) %>%
mutate(
OBS_VALUE = base + rnorm(n(), 0, 1.5),
OBS_VALUE = pmax(OBS_VALUE, -2)    # allow mild deflation but not < -2%
) %>%
select(-base)
message("  Sample data generated: ",
n_distinct(df$REF_AREA), " countries x ", length(years), " years.")
return(df)
}
countries <- tribble(
~country_name,       ~label,
"United States",     "USA",
"Germany",           "DEU",
"Brazil",            "BRA",
"South Africa",      "ZAF",
"Japan",             "JPN",
"United Kingdom",    "GBR",
"India",             "IND",
"Nigeria",           "NGA",
"Australia",         "AUS",
"Argentina",         "ARG"
)
start_year <- 2000
end_year   <- 2022
message("Fetching unemployment data...")
unemp_raw <- fetch_undata(
series_id = "SL_TLF_UEM",
countries = countries$country_name,
start     = start_year,
end       = end_year
)
message("Fetching CPI inflation data...")
cpi_raw <- fetch_undata(
series_id = "FP_CPI_TOTL_ZG",
countries = countries$country_name,
start     = start_year,
end       = end_year
)
# --- 5a. Unemployment ---
unemp_clean <- unemp_raw %>%
# Rename columns to intuitive names
select(country = REF_AREA, year = TIME_PERIOD, unemp_rate = OBS_VALUE) %>%
mutate(
year       = as.integer(year),
unemp_rate = as.numeric(unemp_rate)
) %>%
filter(country %in% countries$country_name)
# --- 5b. Inflation ---
cpi_clean <- cpi_raw %>%
select(country = REF_AREA, year = TIME_PERIOD, inflation = OBS_VALUE) %>%
mutate(
year      = as.integer(year),
inflation = as.numeric(inflation)
) %>%
filter(country %in% countries$country_name)
# --- 5c. Merge into a single tidy panel (one row = one country-year) ---
panel <- unemp_clean %>%
inner_join(cpi_clean, by = c("country", "year")) %>%
left_join(countries, by = c("country" = "country_name")) %>%
drop_na(unemp_rate, inflation)    # remove rows missing either variable
# Quick diagnostic — print dimensions and missing value counts
cat("\nPanel:", nrow(panel), "obs across", n_distinct(panel$country),
"countries (", min(panel$year), "-", max(panel$year), ")\n")
panel %>%
summarise(across(everything(), ~sum(is.na(.)))) %>%
print()
# --- 5d. Country-level averages for the scatter plot ---
# Each country is reduced to one point: its 2000-2022 mean for each variable
country_avgs <- panel %>%
group_by(country, label) %>%
summarise(
mean_unemp     = mean(unemp_rate, na.rm = TRUE),
mean_inflation = mean(inflation,  na.rm = TRUE),
.groups = "drop"
)
cat("\nCountry averages:\n")
print(country_avgs)
# Shared publication-style theme applied to both plots
theme_macro <- theme_minimal(base_size = 12) +
theme(
plot.title       = element_text(face = "bold", size = 14),
plot.subtitle    = element_text(colour = "grey40", size = 10),
plot.caption     = element_text(colour = "grey50", size = 8, hjust = 0),
axis.title       = element_text(size = 10),
legend.position  = "bottom",
legend.title     = element_text(size = 9),
panel.grid.minor = element_blank()
)
p1 <- panel %>%
ggplot(aes(x = year, y = unemp_rate, colour = country, group = country)) +
geom_line(linewidth = 0.8, alpha = 0.85) +
geom_point(size = 1.2, alpha = 0.7) +
# Shaded bands highlight the two major global shocks
annotate("rect", xmin = 2008, xmax = 2010,
ymin = -Inf, ymax = Inf, fill = "steelblue", alpha = 0.08) +
annotate("rect", xmin = 2020, xmax = 2021,
ymin = -Inf, ymax = Inf, fill = "firebrick", alpha = 0.08) +
annotate("text", x = 2009,   y = Inf, label = "GFC",
vjust = 2, size = 3, colour = "steelblue4") +
annotate("text", x = 2020.5, y = Inf, label = "COVID",
vjust = 2, size = 3, colour = "firebrick4") +
scale_colour_brewer(palette = "Paired", name = "Country") +
scale_x_continuous(breaks = seq(2000, 2022, by = 4)) +
scale_y_continuous(labels = label_percent(scale = 1, suffix = "%")) +
labs(
title    = "Unemployment Rates Across Selected Economies, 2000-2022",
subtitle = "Shaded regions indicate the Global Financial Crisis (GFC) and COVID-19 shock",
x        = "Year",
y        = "Unemployment Rate (% of labour force)",
caption  = "Source: UNdata API (ILO Statistics). Retrieved April 2026."
) +
theme_macro
p1
p2 <- country_avgs %>%
ggplot(aes(x = mean_unemp, y = mean_inflation, label = label)) +
# OLS trend line with shaded confidence interval
geom_smooth(method = "lm", se = TRUE, colour = "grey60",
linetype = "dashed", linewidth = 0.8, alpha = 0.15) +
geom_point(aes(colour = label), size = 4, alpha = 0.9) +
# Country labels that automatically avoid overlapping each other
geom_text_repel(size = 3.2, fontface = "bold",
box.padding = 0.4, point.padding = 0.3) +
# Dotted reference lines at the sample means
geom_vline(xintercept = mean(country_avgs$mean_unemp),
linetype = "dotted", colour = "grey50", linewidth = 0.5) +
geom_hline(yintercept = mean(country_avgs$mean_inflation),
linetype = "dotted", colour = "grey50", linewidth = 0.5) +
scale_colour_brewer(palette = "Paired", guide = "none") +
scale_x_continuous(labels = label_percent(scale = 1, suffix = "%")) +
scale_y_continuous(labels = label_percent(scale = 1, suffix = "%")) +
labs(
title    = "Cross-Country Phillips Curve: Inflation vs. Unemployment (2000-2022 Averages)",
subtitle = "Dashed line = OLS fit. Dotted lines = sample means. Each point = one country.",
x        = "Mean Unemployment Rate (% of labour force)",
y        = "Mean CPI Inflation Rate (annual %)",
caption  = "Source: UNdata API (ILO & UNSD Statistics). Retrieved April 2026."
) +
theme_macro
p2
# Create output folders if they do not already exist
dir.create("figures", showWarnings = FALSE)
dir.create("data",    showWarnings = FALSE)
ggsave("figures/plot1_unemployment_timeseries.png",
plot = p1, width = 10, height = 6, dpi = 300)
ggsave("figures/plot2_phillips_curve_scatter.png",
plot = p2, width = 9, height = 7, dpi = 300)
# Save the cleaned data so others can reproduce the analysis without re-fetching
write_csv(panel,        "data/panel_clean.csv")
write_csv(country_avgs, "data/country_averages.csv")
message("Done! Figures saved to /figures and data saved to /data.")
phillips_ols <- lm(mean_inflation ~ mean_unemp, data = country_avgs)
summary(phillips_ols)
